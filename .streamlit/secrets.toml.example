# Kopieer dit naar secrets.toml en pas aan
# Voeg gebruikers toe als [gebruikers] key = value paren
[gebruikers]
tim = "wachtwoord-hier"
collega = "ander-wachtwoord"

# Rol per gebruiker. "volledig" = alle pagina's incl. Vandaag/Gisteren/Analyse Incidenten.
# "performance" = alleen Performance-pagina.
[rollen]
tim = "volledig"
collega = "performance"

# Optioneel: GitHub-PAT voor het opslaan van incident-reasons vanuit Streamlit Cloud.
# PAT moet 'contents:write' scope hebben op de repo.
# Lokaal kun je dit blok weglaten — dan wordt naar data/reasons.json geschreven.
[github]
token = "ghp_xxx"
repo = "Meditatim-create/action-portal-scraper"
